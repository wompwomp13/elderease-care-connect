rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isAllowedSignupRole();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if false;

      function isAllowedSignupRole() {
        return request.resource.data.role in ['elderly', 'companion'];
      }
    }

    // Public volunteer applications (landing page)
    match /pendingVolunteers/{docId} {
      allow create: if true
        && ('fullName' in request.resource.data)
        && ('email' in request.resource.data)
        && ('services' in request.resource.data)
        && request.resource.data.status == 'pending';

      allow read: if isApprovedVolunteer() || isSignedIn();

      allow update: if isAdmin()
        || (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','decidedAt']))
        || (isSignedIn() && resource.data.email == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profilePhotoUrl','profilePhotoStoragePath']));

      allow delete: if isAdmin();

      function isApprovedVolunteer() {
        return resource.data.status == 'approved';
      }
    }

    match /volunteers/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /serviceRequests/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Assignments (admin or preferred volunteer creates)
    match /assignments/{id} {
      allow create: if isSignedIn() && (
        (isAdmin()
          && ('requestId' in request.resource.data)
          && ('volunteerEmail' in request.resource.data))
        ||
        (request.resource.data.acceptedByVolunteer == true
          && (request.resource.data.volunteerEmail == request.auth.token.email
            || (request.resource.data.volunteerUid != null && request.resource.data.volunteerUid == request.auth.uid))
          && ('requestId' in request.resource.data)
          && ('volunteerEmail' in request.resource.data)
          && ('status' in request.resource.data)
          && request.resource.data.status == 'assigned')
      );

      allow read: if isSignedIn();

      allow update: if isSignedIn() && (
        (
          (resource.data.volunteerEmail == request.auth.token.email
            || (('volunteerUid' in resource.data) && resource.data.volunteerUid == request.auth.uid))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','rated','awaitingGuardianConfirm','updatedAt','declinedAt','declineReason','acceptedByVolunteer','acceptedByVolunteerAt'])
        )
        ||
        (
          (('elderUserId' in resource.data) && resource.data.elderUserId == request.auth.uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['guardianConfirmed','updatedAt'])
        )
        ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // Notifications (volunteer decline alerts for guardian and admin)
    match /notifications/{id} {
      allow create: if isSignedIn()
        && ('recipientUid' in request.resource.data)
        && ('type' in request.resource.data)
        && ('title' in request.resource.data)
        && ('body' in request.resource.data)
        && ('createdAt' in request.resource.data);
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.recipientUid == request.auth.uid
        || (resource.data.recipientUid == 'ADMIN' && isAdmin())
        || isAdmin()
      );
      allow delete: if isSignedIn();
    }

    match /ratings/{id} {
      allow create: if isSignedIn()
        && ('assignmentId' in request.resource.data)
        && ('volunteerEmail' in request.resource.data)
        && ('rating' in request.resource.data)
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;
      allow read: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Volunteer time off (full-day unavailability) — companions CRUD own docs; signed-in users read for scheduling
    match /volunteerLeave/{leaveId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && volunteerLeaveCreateValid();
      allow update: if isSignedIn() && volunteerLeaveUpdateValid();
      allow delete: if isSignedIn() && volunteerLeaveDeleteValid();

      function volunteerPendingDoc(docId) {
        return get(/databases/$(database)/documents/pendingVolunteers/$(docId));
      }
      function companionOwnsVolunteerDoc(docId) {
        return volunteerPendingDoc(docId).data.status == 'approved'
          && volunteerPendingDoc(docId).data.email == request.auth.token.email;
      }
      function volunteerLeaveCreateValid() {
        let d = request.resource.data;
        return request.auth.token.email != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'companion'
          && d.keys().hasAll(['volunteerDocId', 'volunteerEmail', 'startDayMs', 'endDayMs', 'createdAt', 'updatedAt'])
          && d.volunteerDocId is string
          && d.volunteerEmail is string
          && d.startDayMs is int
          && d.endDayMs is int
          && d.startDayMs <= d.endDayMs
          && d.volunteerEmail == request.auth.token.email
          && companionOwnsVolunteerDoc(d.volunteerDocId)
          && (!('reason' in d) || d.reason is string)
          && (!('note' in d) || d.note is string);
      }
      function volunteerLeaveDeleteValid() {
        let d = resource.data;
        return request.auth.token.email != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'companion'
          && d.volunteerEmail == request.auth.token.email
          && companionOwnsVolunteerDoc(d.volunteerDocId);
      }
      function volunteerLeaveUpdateValid() {
        let next = request.resource.data;
        let prev = resource.data;
        return request.auth.token.email != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'companion'
          && prev.volunteerDocId == next.volunteerDocId
          && prev.volunteerEmail == next.volunteerEmail
          && next.volunteerEmail == request.auth.token.email
          && companionOwnsVolunteerDoc(next.volunteerDocId)
          && next.startDayMs is int
          && next.endDayMs is int
          && next.startDayMs <= next.endDayMs
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['startDayMs', 'endDayMs', 'reason', 'note', 'updatedAt']);
      }
    }

    match /formMetrics/{id} {
      allow create: if true
        && ('type' in request.resource.data)
        && ('durationMs' in request.resource.data);
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'admin@gmail.com';
    }
  }
}
